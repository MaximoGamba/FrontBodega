# Cloudinary — necesario para subir imágenes de productos desde el panel admin
# Crear cuenta en https://cloudinary.com y copiar estos valores desde el dashboard
VITE_CLOUDINARY_CLOUD_NAME=tu_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=tu_upload_preset

# URLs de microservicios — apuntar a cada servicio según el entorno
# En desarrollo local todos suelen correr en el mismo host con distintos puertos
VITE_AUTH_URL=http://localhost:4002
VITE_VINOS_URL=http://localhost:4002
VITE_CATALOGOS_URL=http://localhost:4002
VITE_USUARIOS_URL=http://localhost:4002
VITE_PEDIDOS_URL=http://localhost:4002
